{
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "sent", "kind", "pack_version", "target", "files", "hashes", "message_ids", "sent_at"],
  "properties": {
    "ok": {"const": true},
    "sent": {"const": true},
    "kind": {"const": "review-md-files"},
    "pack_version": {"const": "review_pack_v2"},
    "target": {"type": "string", "minLength": 1},
    "files": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+\\.md$"},
      "allOf": [
        {"contains": {"const": "THINKING.md"}},
        {"contains": {"const": "LOOP_DESIGN.md"}},
        {"contains": {"const": "ROADMAP.md"}},
        {"contains": {"const": "LAUNCH_GOAL.md"}}
      ]
    },
    "hashes": {
      "type": "object",
      "minProperties": 4,
      "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
    },
    "message_ids": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 1}},
    "sent_at": {"type": "string", "minLength": 1},
    "extensions": {"type": "object"}
  }
}
